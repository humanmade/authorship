{
  "extends": "@wordpress/stylelint-config/scss-stylistic",
  "rules": {
    "@stylistic/max-line-length": null,
    "max-nesting-depth": null,
    "rule-empty-line-before": null,
    "selector-class-pattern": null
  },
  "ignoreFiles": [
    "**/*.json",
    "**/*.ts",
    "**/*.tsx",
    "build/**",
    "lib/**",
    "node_modules/**",
    "tests/wordpress/**",
    "vendor/**"
  ]
}
